# --- M0 required ---
PI_TELEGRAM_TOKEN=
PI_TELEGRAM_ALLOWED_USER_ID=
PI_GITHUB_SANDBOX_REPO=
PI_DB_PATH=./era.db

# --- M1 required ---
PI_OPENROUTER_API_KEY=

# --- M2 required (GitHub App — replaces classic PAT) ---
PI_GITHUB_APP_ID=
PI_GITHUB_APP_INSTALLATION_ID=
PI_GITHUB_APP_PRIVATE_KEY=           # base64-encoded .pem contents (single line)

# --- M1 optional (defaults shown) ---
# PI_MODEL=moonshotai/kimi-k2.6
# PI_MAX_TOKENS_PER_TASK=500000
# PI_MAX_COST_CENTS_PER_TASK=20
# PI_MAX_ITERATIONS_PER_TASK=60
# PI_MAX_WALL_CLOCK_SECONDS=1800

# 0G testnet (M7-B onward)
# Get testnet ZG from https://docs.0g.ai → faucet
PI_ZG_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HEX
PI_ZG_EVM_RPC=https://evmrpc-testnet.0g.ai
PI_ZG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
# KV node endpoint — separate from the ZGS storage nodes selected by the indexer.
# The indexer selects ZGS (file-storage) nodes; KV reads/writes need a dedicated
# KV node. Testnet example: http://3.101.147.150:6789
PI_ZG_KV_NODE=http://YOUR_KV_NODE:6789

# 0G Compute (M7-C onward) — sealed inference via TEE-signed response
# Generated via 0g-compute-cli (see scripts/zg-compute-smoke/ for setup notes)
PI_ZG_COMPUTE_ENDPOINT=https://YOUR_PROVIDER_URL
PI_ZG_COMPUTE_BEARER=app-sk-YOUR_HEX_TOKEN
PI_ZG_COMPUTE_MODEL=qwen-2.5-7b-instruct

# 0G iNFT contract (M7-D onward)
# Deployed via contracts/script/Deploy.s.sol — see docs/superpowers/specs/2026-04-27-m7d-inft-design.md
# Reference deployment on 0G Galileo testnet: 0x33847c5500C2443E2f3BBf547d9b069B334c3D16
# Replace with your own deployment if you re-deploy the contract.
PI_ZG_INFT_CONTRACT_ADDRESS=0xREPLACE_WITH_DEPLOYED_ADDRESS

# ENS subname resolver (M7-E onward) — Sepolia testnet
# Parent name must be registered + wrapped on sepolia.app.ens.domains to the
# wallet derived from PI_ZG_PRIVATE_KEY. See docs/superpowers/specs/2026-04-27-m7e-ens-design.md.
# Pre-flight check:
#   cast call 0x0635513f179D50A207757E05759CbD106d7dFcE8 \
#     'ownerOf(uint256)(address)' $(cast namehash $PI_ENS_PARENT_NAME) \
#     --rpc-url $PI_ENS_RPC
# must return signer address. Wallet needs ≥0.01 Sepolia ETH (Google Cloud / Alchemy faucet).
PI_ENS_RPC=https://ethereum-sepolia-rpc.publicnode.com
PI_ENS_PARENT_NAME=vaibhav-era.eth
